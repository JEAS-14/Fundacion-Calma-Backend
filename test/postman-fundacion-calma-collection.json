{
  "info": {
    "name": "Fundacion-Calma-API",
    "description": "Collection para Postman - Auth y Usuarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login Admin",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@calma.org\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3005/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3005",
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Crear Usuario Practicante",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre_completo\": \"Juan\",\n  \"apellido_completo\": \"Perez\",\n  \"email\": \"juan@calma.org\",\n  \"password\": \"calma123\",\n  \"puesto\": \"Practicante\",\n  \"rol\": \"Practicante\"\n}"
        },
        "url": {
          "raw": "http://localhost:3005/api/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3005",
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Listar Usuarios",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "http://localhost:3005/api/auth/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3005",
          "path": ["api", "auth", "users"]
        }
      }
    },
    {
      "name": "Actualizar Usuario (fecha fin contrato)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fecha_fin_contrato\": \"2026-12-31T23:59:59.000Z\",\n  \"estado\": \"ACTIVO\"\n}"
        },
        "url": {
          "raw": "http://localhost:3005/api/auth/users/{{userId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3005",
          "path": ["api", "auth", "users", "{{userId}}"]
        }
      }
    }
  ]
}
